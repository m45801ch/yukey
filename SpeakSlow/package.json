{
  "name": "speakslow",
  "version": "1.0.14",
  "description": "聲聲慢 SpeakSlow - 專為中文打造、最快的本地語音輸入（sherpa-onnx）",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "node start-electron.js",
    "dev": "concurrently -k -r \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:main": "cross-env NODE_ENV=development electronmon .",
    "dev:renderer": "cd src && vite",
    "build": "cd src && vite build && cd .. && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "build:renderer": "cd src && vite build",
    "prepare:python": "pip install sherpa-onnx numpy opencc edge-tts pyinstaller && python download_all_models.py",
    "build:backend": "node scripts/build-backend.mjs",
    "build:win": "electron-builder --win",
    "dist:win": "npm run build:backend && npm run build:renderer && electron-builder --win",
    "lint": "cd src && eslint .",
    "preview": "cd src && vite preview",
    "clean": "node cleanup.js && rm -rf python"
  },
  "electronmon": {
    "patterns": [
      "!dist/**",
      "!src/dist/**",
      "!package-lock.json",
      "!build_pyi/**",
      "!build/**",
      "!web/**",
      "!poc-sherpa/**",
      "!assets/logo-build/**",
      "!.venv/**"
    ]
  },
  "keywords": [
    "dictation",
    "speech-to-text",
    "sherpa-onnx",
    "ai",
    "voice-input",
    "chinese",
    "electron",
    "desktop-app"
  ],
  "author": {
    "name": "Jeffrey0117"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/notarize": "^3.0.1",
    "@eslint/js": "^9.25.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/vite": "^4.1.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cross-env": "^10.0.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.6.4",
    "electronmon": "^2.0.4",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "node-gyp": "^11.4.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.10",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "lucide-react": "^0.518.0",
    "next-themes": "^0.4.6",
    "opencc-js": "^1.0.5",
    "osascript": "^1.0.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uiohook-napi": "^1.5.4"
  },
  "build": {
    "appId": "com.speakslow.app",
    "productName": "SpeakSlow",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "sherpa_server.py",
      "text_processing.py",
      "package.json",
      "node_modules/**/*",
      "src/dist/**/*",
      "src/helpers/**/*",
      "src/utils/**/*",
      "assets/**/*",
      "!node_modules/.cache/**/*",
      "!src/node_modules/**/*"
    ],
    "asarUnpack": [
      "sherpa_server.py",
      "text_processing.py",
      "node_modules/**/*better-sqlite3*/**/*"
    ],
    "extraResources": [
      {
        "from": "build_pyi/dist/sherpa_server",
        "to": "sherpa-backend"
      },
      {
        "from": "poc-sherpa/sherpa-onnx-paraformer-zh-2023-09-14",
        "to": "sherpa-backend/poc-sherpa/sherpa-onnx-paraformer-zh-2023-09-14"
      },
      {
        "from": "poc-sherpa/sherpa-onnx-paraformer-zh-small-2024-03-09",
        "to": "sherpa-backend/poc-sherpa/sherpa-onnx-paraformer-zh-small-2024-03-09"
      },
      {
        "from": "poc-sherpa/sherpa-onnx-punct-ct-transformer-zh-en-vocab272727-2024-04-12",
        "to": "sherpa-backend/poc-sherpa/sherpa-onnx-punct-ct-transformer-zh-en-vocab272727-2024-04-12"
      },
      {
        "from": "poc-sherpa/silero_vad.onnx",
        "to": "sherpa-backend/poc-sherpa/silero_vad.onnx"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "聲聲慢",
      "include": "build/installer.nsh"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Office",
      "artifactName": "${productName}.${ext}",
      "target": [
        "AppImage"
      ]
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null,
      "artifactName": "${productName}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        }
      ]
    }
  }
}
